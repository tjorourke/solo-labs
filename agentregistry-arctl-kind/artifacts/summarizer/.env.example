# Copy to .env and fill in. The real .env is gitignored.

# Required: the Anthropic key the agent's LiteLlm model reads.
ANTHROPIC_API_KEY=

# Wired by `arctl init agent --local-mcp ./textkit` for local `arctl run`.
# Points the agent at a textkit MCP server running on the host (port 3000),
# e.g. started with `arctl run textkit` in another terminal.
# In the cluster this is injected by the registry from spec.mcpServers instead.
MCP_SERVERS_CONFIG=[{"name":"acme/textkit","type":"remote","url":"http://host.docker.internal:3000/mcp"}]

# Optional
# LOG_LEVEL=
