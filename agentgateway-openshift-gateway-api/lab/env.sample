# Copy to env.sh and fill in. Source it before running the scripts: `source env.sh`
# Nothing in here is committed-secret; env.sh is gitignored locally.

# --- OpenShift install (scripts/00) ---
export CLUSTER_NAME=ocp-gwapi
export BASE_DOMAIN=example.com            # a public Route53 zone you control
export AWS_REGION=us-east-1
export PULL_SECRET=/path/to/pull-secret.json   # from console.redhat.com/openshift/install/pull-secret
export OCP_CHANNEL=stable-4.21            # 4.21 => Gateway API 1.3.0

# --- AWS credentials ---
# IPI "mint" mode needs long-lived creds; SSO/STS temporary creds are rejected
# ("AWS credentials provided by SSOProvider are not valid for default credentials mode").
# Create a dedicated installer IAM user with AdministratorAccess + an access key,
# and export them here (delete the user at teardown).
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=

# --- agentgateway (scripts/03) ---
export AGENTGATEWAY_LICENSE_KEY=          # Solo Enterprise for agentgateway license
export AGW_VERSION=v2026.6.1

# --- app hostname used by the sample app + monitor ---
export APP_HOST=hello.gwtest.${BASE_DOMAIN}
