# Rendered by scripts/04-backend.sh (envsubst). Vars: ${REGION} ${NS} ${GW_NS} ${SECRET}
apiVersion: agentgateway.dev/v1alpha1
kind: AgentgatewayBackend
metadata:
  name: bedrock
  namespace: ${NS}
spec:
  ai:
    provider:
      bedrock:
        # model intentionally UNSET — it is taken from each request, so one
        # backend serves every team's application-inference-profile ARN.
        region: ${REGION}
  policies:
    auth:
      aws:                       # SigV4; NOT the plain auth.secretRef api-key path
        secretRef:
          name: ${SECRET}
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: bedrock
  namespace: ${NS}
spec:
  parentRefs:
    - name: agentgateway-proxy
      namespace: ${GW_NS}
  rules:
    - backendRefs:
        - name: bedrock
          namespace: ${NS}
          group: agentgateway.dev
          kind: AgentgatewayBackend
