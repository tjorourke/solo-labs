# Originally autogenerated by the AgentRegistry CLI. Edited by hand to
# also stage the agent under /var/task/, where the kagent-adk base
# image's bedrock-agentcore wrapper expects to find agent-card.json and
# the module.
#
# kagent runtime continues to use /app/ via the CMD below; AgentCore
# uses /var/task/ via the wrapper baked into the base image.

ARG DOCKER_REGISTRY=ghcr.io
ARG VERSION=0.8.0-beta6
FROM $DOCKER_REGISTRY/kagent-dev/kagent/kagent-adk:$VERSION

WORKDIR /app

COPY solofieldassistant/ solofieldassistant/
COPY pyproject.toml pyproject.toml
COPY README.md README.md
COPY .python-version .python-version

RUN uv sync

# Stage the same agent under /var/task/ so the AgentCore wrapper
# (/var/task/agentcore_wrapper.py) can resolve /var/task/<agent>/agent-card.json
# and import the module.
COPY solofieldassistant/ /var/task/solofieldassistant/

ENV OTEL_SERVICE_NAME=solofieldassistant

CMD ["solofieldassistant"]

